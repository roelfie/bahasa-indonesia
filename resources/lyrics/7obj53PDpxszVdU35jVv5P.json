  "lines": [
    {
      "line_number": 1,
      "original": "Denting piano kala jemari menari",
      "translation": "The piano tinkles as your fingers dance",
      "start_ms": 25800,
      "end_ms": 33289
    },
    {
      "line_number": 2,
      "original": "Nada merambat pelan di kesunyian malam",
      "translation": "The sound creeps softly in the silence of the night",
      "start_ms": 33290,
      "end_ms": 40049
    },
    {
      "line_number": 3,
      "original": "Saat datang rintik hujan",
      "translation": "When the rain comes",
      "start_ms": 40050,
      "end_ms": 45189
    },
    {
      "line_number": 4,
      "original": "Bersama sebuah bayang",
      "translation": "With a shadow",
      "start_ms": 45190,
      "end_ms": 50639
    },
    {
      "line_number": 5,
      "original": "Yang pernah terlupakan",
      "translation": "Which has been forgotten",
      "start_ms": 50640,
      "end_ms": 60889
    },
    {
      "line_number": 6,
      "original": "Hati kecil berbisik untuk kembali padanya",
      "translation": "A small heart whispers to return to him",
      "start_ms": 60890,
      "end_ms": 67919
    },
    {
      "line_number": 7,
      "original": "S'ribu kata menggoda",
      "translation": "A thousand words of teasing",
      "start_ms": 67920,
      "end_ms": 71859
    },
    {
      "line_number": 8,
      "original": "S'ribu sesal di depan mata",
      "translation": "A thousand regrets before your eyes",
      "start_ms": 71860,
      "end_ms": 76049
    },
    {
      "line_number": 9,
      "original": "S'perti menjelma waktu aku tertawa",
      "translation": "It's like it materializes when I laugh",
      "start_ms": 76050,
      "end_ms": 84869
    },
    {
      "line_number": 10,
      "original": "Kala memberimu dosa",
      "translation": "When giving you sin",
      "start_ms": 84870,
      "end_ms": 93829
    },
    {
