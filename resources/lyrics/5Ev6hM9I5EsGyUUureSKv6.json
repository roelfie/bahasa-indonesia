      "end_ms": 72159
    },
    {
      "line_number": 9,
      "original": "Seperti angin tak pernah diam",
      "translation": "Like the wind never stops",
      "start_ms": 72160,
      "end_ms": 80039
    },
    {
      "line_number": 10,
      "original": "Selalu beranjak setiap saat",
      "translation": "Always moving all the time",
      "start_ms": 80040,
      "end_ms": 87189
    },
    {
      "line_number": 11,
      "original": "Menebarkan jala asmara",
      "translation": "Spreading the net of romance",
      "start_ms": 87190,
      "end_ms": 93289
    },
    {
      "line_number": 12,
      "original": "Menaburkan aroma luka",
      "translation": "Sprinkles the scent of wounds",
      "start_ms": 93290,
      "end_ms": 100029
    },
    {
      "line_number": 13,
      "original": "Benih kebencian kau tanam",
      "translation": "You planted the seeds of hatred",
      "start_ms": 100030,
      "end_ms": 105999
    },
    {
      "line_number": 14,
      "original": "Bakar ladang gersang",
      "translation": "Burn barren fields",
      "start_ms": 106000,
      "end_ms": 111959
    },
    {
      "line_number": 15,
      "original": "Entah sampai kapan",
      "translation": "Do not know until when",
      "start_ms": 111960,
      "end_ms": 115089
    },
    {
      "line_number": 16,
      "original": "Berhenti menipu diri",
      "translation": "Stop deceiving yourself",
      "start_ms": 115090,
      "end_ms": 121969
    },
    {
