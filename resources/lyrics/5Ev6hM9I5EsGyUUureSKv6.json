  "lines": [
    {
      "line_number": 1,
      "original": "Setiap waktu engkau tersenyum",
      "translation": "Every time you smile",
      "start_ms": 20000,
      "end_ms": 26929
    },
    {
      "line_number": 2,
      "original": "Sudut matamu memancarkan rasa",
      "translation": "The corners of your eyes flash with emotion",
      "start_ms": 26930,
      "end_ms": 35039
    },
    {
      "line_number": 3,
      "original": "Keresahan yang terbenam",
      "translation": "Submerged anxiety",
      "start_ms": 35040,
      "end_ms": 41059
    },
    {
      "line_number": 4,
      "original": "Kerinduan yang tertahan",
      "translation": "Restrained longing",
      "start_ms": 41060,
      "end_ms": 47089
    },
    {
      "line_number": 5,
      "original": "Duka dalam yang tersembunyi",
      "translation": "Hidden deep sorrow",
      "start_ms": 47090,
      "end_ms": 53079
    },
    {
      "line_number": 6,
      "original": "Jauh di lubuk hati",
