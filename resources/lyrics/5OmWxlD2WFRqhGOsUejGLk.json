{
  "track_id": "5OmWxlD2WFRqhGOsUejGLk",
  "track_uri": "spotify:track:5OmWxlD2WFRqhGOsUejGLk",
  "track_name": "Berita Kepada Kawan",
  "album_name": "Aku Ingin Pulang",
  "artist_names": "Ebiet G. Ade",
  "duration_ms": 337989,
  "source_language": "id",
  "target_language": "en",
  "lyrics_source": "lrclib",
  "fetched_at": "2026-05-30T21:02:15.949425+00:00",
  "lines": [
    {
      "line_number": 1,
      "original": "Perjalanan ini terasa sangat menyedihkan",
      "translation": "This trip felt very sad",
      "start_ms": 16110,
      "end_ms": 22919
    },
    {
      "line_number": 2,
      "original": "Sayang engkau tak duduk di sampingku kawan",
      "translation": "It's a shame you don't sit next to me, friend",
      "start_ms": 22920,
      "end_ms": 29599
    },
    {
      "line_number": 3,
      "original": "Banyak cerita yang mestinya kau saksikan",
      "translation": "There are many stories that you should watch",
      "start_ms": 29600,
      "end_ms": 35929
    },
    {
      "line_number": 4,
      "original": "Di tanah kering bebatuan",
      "translation": "On dry land rocks",
      "start_ms": 35930,
      "end_ms": 56449
    },
    {
      "line_number": 5,
      "original": "Tubuhku terguncang dihempas batu jalanan",
      "translation": "My body shook when hit by the road stones",
      "start_ms": 56450,
      "end_ms": 63199
    },
    {
      "line_number": 6,
      "original": "Hati tergetar menampak kering rerumputan",
      "translation": "My heart trembled when I saw the dry grass",
      "start_ms": 63200,
      "end_ms": 69529
    },
    {
      "line_number": 7,
      "original": "Perjalanan ini pun seperti jadi saksi",
      "translation": "This journey is like being a witness",
      "start_ms": 69530,
      "end_ms": 76019
    },
    {
      "line_number": 8,
      "original": "Gembala kecil menangis sedih",
      "translation": "The little shepherd cried sadly",
      "start_ms": 76020,
      "end_ms": 89149
    },
    {
      "line_number": 9,
      "original": "Kawan coba dengar apa jawabnya",
      "translation": "Friends, try to hear what the answer is",
      "start_ms": 89150,
      "end_ms": 95919
    },
    {
      "line_number": 10,
      "original": "Ketika ia kutanya mengapa",
      "translation": "When he asked why",
      "start_ms": 95920,
      "end_ms": 102259
    },
    {
      "line_number": 11,
      "original": "Bapak ibunya telah lama mati",
      "translation": "His mother's father died long ago",
      "start_ms": 102260,
      "end_ms": 108899
    },
    {
      "line_number": 12,
      "original": "Ditelan bencana tanah ini",
      "translation": "Swallowed by this land disaster",
      "start_ms": 108900,
      "end_ms": 115189
    },
    {
      "line_number": 13,
      "original": "Sesampainya di laut",
      "translation": "Arriving at sea",
      "start_ms": 115190,
      "end_ms": 119049
    },
    {
      "line_number": 14,
      "original": "Kukabarkan semua",
      "translation": "I'll tell you everything",
      "start_ms": 119050,
      "end_ms": 122579
    },
    {
      "line_number": 15,
      "original": "Kepada karang kepada ombak kepada matahari",
      "translation": "To the coral, to the waves, to the sun",
      "start_ms": 122580,
      "end_ms": 128989
    },
    {
      "line_number": 16,
      "original": "Tetapi semua diam",
      "translation": "But everyone was silent",
      "start_ms": 128990,
      "end_ms": 132049
    },
    {
      "line_number": 17,
      "original": "Tetapi semua bisu",
      "translation": "But all are mute",
      "start_ms": 132050,
      "end_ms": 136139
    },
    {
      "line_number": 18,
      "original": "Tinggallah ku sendiri",
      "translation": "Just leave me alone",
      "start_ms": 136140,
      "end_ms": 138949
    },
    {
      "line_number": 19,
      "original": "Terpaku menatap langit",
      "translation": "Staring at the sky",
      "start_ms": 138950,
      "end_ms": 145239
    },
    {
      "line_number": 20,
      "original": "Barangkali di sana ada jawabnya",
      "translation": "Maybe there is an answer there",
      "start_ms": 145240,
      "end_ms": 151639
    },
    {
      "line_number": 21,
      "original": "Mengapa di tanahku terjadi bencana",
      "translation": "Why is there a disaster in my land?",
      "start_ms": 151640,
      "end_ms": 158679
    },
    {
      "line_number": 22,
      "original": "Mungkin Tuhan mulai bosan",
      "translation": "Maybe God is getting bored",
      "start_ms": 158680,
      "end_ms": 162539
    },
    {
      "line_number": 23,
      "original": "Melihat tingkah kita",
      "translation": "Look at our behavior",
      "start_ms": 162540,
      "end_ms": 165609
    },
    {
      "line_number": 24,
      "original": "Yang selalu salah dan bangga dengan dosa-dosa",
      "translation": "Who is always wrong and proud of his sins",
      "start_ms": 165610,
      "end_ms": 172469
    },
    {
      "line_number": 25,
      "original": "Atau alam mulai enggan",
      "translation": "Or nature starts to be reluctant",
      "start_ms": 172470,
      "end_ms": 175519
    },
    {
      "line_number": 26,
      "original": "Bersahabat dengan kita",
      "translation": "Be friendly with us",
      "start_ms": 175520,
      "end_ms": 179019
    },
    {
      "line_number": 27,
      "original": "Coba kita bertanya pada rumput yang bergoyang",
      "translation": "Let's ask the swaying grass",
