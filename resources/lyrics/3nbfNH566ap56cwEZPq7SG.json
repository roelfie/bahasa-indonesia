      "line_number": 1,
      "original": "Di daun yang ikut mengalir lembut",
      "translation": "In the leaves that flow gently",
      "start_ms": 1160,
      "end_ms": 6029
    },
    {
      "line_number": 2,
      "original": "Terbawa sungai ke ujung mata",
      "translation": "Carried by the river to the edge of the eye",
      "start_ms": 6030,
      "end_ms": 11569
    },
    {
      "line_number": 3,
      "original": "Dan aku mulai takut terbawa cinta",
      "translation": "And I'm starting to be afraid of being carried away by love",
      "start_ms": 11570,
      "end_ms": 17679
    },
    {
      "line_number": 4,
      "original": "Menghirup rindu yang sesakkan dada",
      "translation": "Breathe in the longing that is tight in your chest",
      "start_ms": 17680,
      "end_ms": 24849
    },
    {
      "line_number": 5,
      "original": "Jalanku hampa dan kusentuh dia",
      "translation": "My path is empty and I touch him",
      "start_ms": 24850,
      "end_ms": 30559
    },
    {
      "line_number": 6,
      "original": "Terasa hangat, oh, di dalam hati",
      "translation": "It feels warm, oh, inside",
      "start_ms": 30560,
      "end_ms": 36359
    },
    {
      "line_number": 7,
      "original": "Kupegang erat dan kuhalangi waktu",
      "translation": "I hold it tightly and block out time",
      "start_ms": 36360,
      "end_ms": 42149
    },
    {
      "line_number": 8,
      "original": "Tak urung jua kulihatnya pergi",
      "translation": "I couldn't help but see him go",
      "start_ms": 42150,
      "end_ms": 61359
    },
    {
      "line_number": 9,
      "original": "Tak pernah kuragu dan s'lalu kuingat",
      "translation": "I never doubted it and I always remember it",
      "start_ms": 61360,
      "end_ms": 66519
    },
    {
      "line_number": 10,
      "original": "Kerlingan matamu dan sentuhan hangat",
