      "start_ms": 66520,
      "end_ms": 72389
    },
    {
      "line_number": 11,
      "original": "Ku saat itu takut mencari makna",
      "translation": "At that time I was afraid to look for meaning",
      "start_ms": 72390,
      "end_ms": 77929
    },
    {
      "line_number": 12,
      "original": "Tumbuhkan rasa yang sesakkan dada",
      "translation": "Develop a feeling of chest tightness",
      "start_ms": 77930,
      "end_ms": 85449
    },
    {
      "line_number": 13,
      "original": "Kau datang dan pergi, oh, begitu saja",
      "translation": "You come and go, oh, just like that",
      "start_ms": 85450,
      "end_ms": 91239
    },
    {
      "line_number": 14,
      "original": "Semua kut'rima apa adanya",
